job "php-app" {
  datacenters = ["dc1"]

  group "web-server" {
    network {
      mode = "bridge"
      port "http" { to = 80 }
    }

    service {
      name = "php-app"
      port = "http"
      provider = "nomad"
      tags = [
        "traefik.enable=true",
        "traefik.http.routers.phpapp.rule=Host(`php.b220.ru`)",
        "traefik.http.routers.phpapp.entrypoints=websecure",
        "traefik.http.routers.phpapp.tls=true",
        "traefik.http.routers.phpapp.tls.certresolver=myresolver"
      ]
    }

    task "php" {
      driver = "docker"

      artifact {
        source      = "https://s3.ru1.storage.beget.cloud/2d858c4489de-black-willow/code1.tar.gz"
        destination = "local/repo"
        options {
          archive = true # Это заставит Nomad распаковать .tar.gz
        }
      }

      config {
        image = "php:8.2-fpm-alpine"
        command = "/bin/sh"
        args = ["-c", "chmod -R 755 /local/repo && php-fpm"]
      }
    }

    task "nginx" {
      driver = "docker"

      artifact {
        source      = "https://s3.ru1.storage.beget.cloud/2d858c4489de-black-willow/code1.tar.gz"
        destination = "local/repo"
        options {
          archive = true
        }
      }

      config {
        image = "nginx:alpine"
        volumes = [
          "local/nginx.conf:/etc/nginx/conf.d/default.conf"
        ]
        command = "/bin/sh"
        args = ["-c", "chmod -R 755 /local/repo && nginx -g 'daemon off;'"]
      }

      template {
        data = <<EOH
user root; # Работаем от root, чтобы не было 403

server {
    listen 80;
    root /local/repo;
    index index.php;
    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }
    location ~ \.php$ {
        fastcgi_pass 127.0.0.1:9000;
        fastcgi_index index.php;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME /local/repo$fastcgi_script_name;
    }
}
EOH
        destination = "local/nginx.conf"
      }
    }
  }
}
