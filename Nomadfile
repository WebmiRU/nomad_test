job "nginx-static" {
  datacenters = ["dc1"]

  group "web" {
    network {
      mode = "bridge"
      port "http" { to = 80 }
    }

    service {
      name     = "nginx-static"
      port     = "http"
      provider = "nomad"
      tags = [
        "traefik.enable=true",
        "traefik.http.routers.static.rule=Host(`php.b220.ru`)",
        "traefik.http.routers.static.entrypoints=websecure",
        "traefik.http.routers.static.tls=true",
        "traefik.http.routers.static.tls.certresolver=myresolver"
      ]
    }

    # Задача 1: PHP-FPM
    task "php" {
      driver = "docker"

      artifact {
        source      = "https://s3.ru1.storage.beget.cloud/2d858c4489de-black-willow/code2.zip"
        destination = "local/repo"
      }

      config {
        image = "php:8.2-fpm-alpine"
        # PHP должен видеть те же файлы, что и Nginx
        volumes = [
          "local/repo:/local/repo"
        ]
      }
    }

    # Задача 2: Nginx
    task "server" {
      driver = "docker"

      config {
        image = "nginx:alpine"
        volumes = [
          "local/nginx.conf:/etc/nginx/conf.d/default.conf",
          "local/repo:/local/repo"
        ]
      }

      template {
        data = <<EOH
server {
    listen 80;
    root /local/repo;
    index index.php index.html;

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ \.php$ {
        fastcgi_split_path_info ^(.+\.php)(/.+)$;
        # Так как mode = "bridge", php-fpm доступен на localhost
        fastcgi_pass 127.0.0.1:9000;
        fastcgi_index index.php;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_param PATH_INFO $fastcgi_path_info;
    }
}
EOH
        destination = "local/nginx.conf"
      }
    }
  }
}
