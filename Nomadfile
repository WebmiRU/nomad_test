job "nginx-static" {
  datacenters = ["dc1"]

  group "web" {
    network {
      mode = "bridge"
      port "http" { to = 80 }
    }

    task "server" {
      driver = "docker"

      artifact {
        source      = "https://s3.ru1.storage.beget.cloud/2d858c4489de-black-willow/code2.zip"
        destination = "local/"
        options {
          # Только эта опция в кавычках заставляет Nomad распаковать архив
          archive = "true"
        }
      }

      config {
        image = "nginx:alpine"
        volumes = [
          "local/nginx.conf:/etc/nginx/conf.d/default.conf"
        ]
      }

      template {
        data = <<EOH
server {
    listen 80;
    root /local;
    index index.php index.html;
    location / {
        try_files $uri $uri/ =404;
    }
}
EOH
        destination = "local/nginx.conf"
      }
    }
  }
}
