job "php-app" {
  datacenters = ["dc1"]

  group "web-server" {
    network {
      mode = "bridge"
      port "http" { to = 80 }
    }

    service {
      name = "php-app"
      port = "http"
      provider = "nomad"
      tags = [
        "traefik.enable=true",
        "traefik.http.routers.phpapp.rule=Host(`php.b220.ru`)",
        "traefik.http.routers.phpapp.entrypoints=websecure",
        "traefik.http.routers.phpapp.tls=true",
        "traefik.http.routers.phpapp.tls.certresolver=myresolver"
      ]
    }

    task "php" {
      driver = "docker"

      # Скачиваем в ОБЩУЮ папку группы (alloc)
      artifact {
        source      = "https://s3.ru1.storage.beget.cloud"
        destination = "alloc/repo"
        options {
          archive = true
        }
      }

      config {
        image = "php:8.2-fpm-alpine"
        # Мапим из общей папки alloc
        volumes = [
          "alloc/repo:/var/www/html"
        ]
      }

      resources {
        disk = 100
        memory = 128
      }
    }

    task "nginx" {
      driver = "docker"

      config {
        image = "nginx:alpine"
        # Прокидываем конфиг и ТУ ЖЕ общую папку alloc
        volumes = [
          "local/nginx.conf:/etc/nginx/conf.d/default.conf",
          "alloc/repo:/var/www/html"
        ]
      }

      template {
        data = <<EOH
server {
    listen 80;
    root /var/www/html;
    index index.php;
    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }
    location ~ \.php$ {
        fastcgi_pass 127.0.0.1:9000;
        fastcgi_index index.php;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME /var/www/html$fastcgi_script_name;
    }
}
EOH
        destination = "local/nginx.conf"
      }
    }
  }
}
