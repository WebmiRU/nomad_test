job "php-app" {
  datacenters = ["dc1"]

  group "web" {

    network {
      mode = "bridge"

      port "http" { to = 80 }
      port "fpm"  { to = 9000 }
    }

    # 👉 Общий volume
    volume "app" {
      type      = "tmpfs"
      read_only = false
    }

    service {
      name = "php-app"
      port = "http"
      provider = "nomad"

      tags = [
        "traefik.enable=true",
        "traefik.http.routers.phpapp.rule=Host(`php.b220.ru`)",
        "traefik.http.routers.phpapp.entrypoints=websecure",
        "traefik.http.routers.phpapp.tls=true",
        "traefik.http.routers.phpapp.tls.certresolver=myresolver"
      ]
    }

    # 🔥 INIT TASK (единственный, кто работает с архивом)
    task "init" {
      driver = "docker"

      lifecycle {
        hook = "prestart"
      }

      volume_mount {
        volume      = "app"
        destination = "/app"
      }

      artifact {
        source      = "https://s3.ru1.storage.beget.cloud/2d858c4489de-black-willow/code1.tar.gz"
        destination = "local"
      }

      config {
        image = "alpine:3.19"

        command = "sh"
        args = [
          "-c",
          <<EOF
set -e
echo "Extracting archive..."
tar -xzf /local/code1.tar.gz -C /app

echo "Fixing permissions..."
chmod -R 755 /app

echo "Done"
EOF
        ]
      }
    }

    # 🐘 PHP-FPM
    task "php" {
      driver = "docker"

      volume_mount {
        volume      = "app"
        destination = "/var/www/html"
      }

      config {
        image = "php:8.2-fpm-alpine"
        ports = ["fpm"]
      }

      resources {
        cpu    = 100
        memory = 128
      }
    }

    # 🌐 NGINX
    task "nginx" {
      driver = "docker"

      volume_mount {
        volume      = "app"
        destination = "/var/www/html"
      }

      config {
        image = "nginx:alpine"
        ports = ["http"]

        volumes = [
          "local/nginx.conf:/etc/nginx/conf.d/default.conf"
        ]
      }

      template {
        destination = "local/nginx.conf"
        data = <<EOF
server {
    listen 80;

    root /var/www/html;
    index index.php index.html;

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ \.php$ {
        fastcgi_pass 127.0.0.1:${NOMAD_PORT_fpm};
        fastcgi_index index.php;

        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME /var/www/html$fastcgi_script_name;
    }
}
EOF
      }
    }
  }
}