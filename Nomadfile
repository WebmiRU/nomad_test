job "nginx-test" {
  datacenters = ["dc1"]
  group "web" {
    network {
      mode = "bridge"
      port "http" { to = 80 }
    }

    task "server" {
      driver = "docker"

      artifact {
        source      = "https://s3.ru1.storage.beget.cloud/2d858c4489de-black-willow/code2.zip"
        # Скачиваем прямо в local задачи
        destination = "local/repo"
        options { archive = true }
      }

      config {
        image = "nginx:alpine"
        # МЫ НЕ МАПИМ ПАПКУ, а правим конфиг Nginx смотреть в /local/repo
        volumes = ["local/nginx.conf:/etc/nginx/conf.d/default.conf"]
      }

      template {
        data = <<EOH
server {
    listen 80;
    # Nomad прокидывает свою папку local в /local контейнера автоматически
    root /local/repo;
    index index.php index.html;
    location / {
        try_files $uri $uri/ =404;
    }
}
EOH
        destination = "local/nginx.conf"
      }
    }
  }
}
