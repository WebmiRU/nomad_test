    task "server" {
      driver = "docker"

      artifact {
        source      = "https://s3.ru1.storage.beget.cloud/2d858c4489de-black-willow/code2.zip"
        destination = "local/repo"
        options {
          # Без этой строки Nomad просто скачивает файл как есть
          archive = true
        }
      }

      config {
        image = "nginx:alpine"
        volumes = ["local/nginx.conf:/etc/nginx/conf.d/default.conf"]
      }

      template {
        data = <<EOH
server {
    listen 80;
    root /local/repo;
    index index.php index.html;
    location / {
        try_files $uri $uri/ =404;
    }
}
EOH
        destination = "local/nginx.conf"
      }
    }
