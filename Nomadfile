    task "server" {
      driver = "docker"

      artifact {
        source      = "https://s3.ru1.storage.beget.cloud/2d858c4489de-black-willow/code2.zip"
        # Качаем прямо в корень папки local
        destination = "local"
        options {
          archive = "true"
        }
      }

      config {
        image = "nginx:alpine"
        volumes = [
          "local/nginx.conf:/etc/nginx/conf.d/default.conf"
          # Папка local внутри контейнера по умолчанию доступна как /local
        ]
      }

      template {
        data = <<EOH
server {
    listen 80;
    # Проверяем: если в zip лежит папка code2, путь будет /local/code2
    # Если в zip сразу файлы, то просто /local
    root /local;
    index index.php index.html;
    location / {
        try_files $uri $uri/ =404;
    }
}
EOH
        destination = "local/nginx.conf"
      }
    }
