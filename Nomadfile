job "nginx-static" {
  datacenters = ["dc1"]

  group "web" {
    network {
      mode = "bridge"
      port "http" { to = 80 }
    }

    service {
      name = "nginx-static"
      port = "http"
      provider = "nomad"
      tags = [
        "traefik.enable=true",
        "traefik.http.routers.static.rule=Host(`php.b220.ru`)",
        "traefik.http.routers.static.entrypoints=websecure",
        "traefik.http.routers.static.tls=true",
        "traefik.http.routers.static.tls.certresolver=myresolver"
      ]
    }

    task "server" {
      driver = "docker"

      artifact {
        source      = "https://s3.ru1.storage.beget.cloud/2d858c4489de-black-willow/code2.zip"
        destination = "local/repo"
        options {
          archive = "true"
        }
      }

      config {
        image = "nginx:alpine"
        # Пробрасываем распакованную папку и конфиг в контейнер
        volumes = [
          "local/nginx.conf:/etc/nginx/conf.d/default.conf",
          "local/repo:/usr/share/nginx/html"
        ]
      }

      template {
        data = <<EOH
server {
    listen 80;
    # Если в архиве сразу файлы — оставляем /usr/share/nginx/html
    # Если в архиве папка — добавим ее имя в путь позже
    root /usr/share/nginx/html;
    index index.html index.php;
    location / {
        try_files $uri $uri/ =404;
    }
}
EOH
        destination = "local/nginx.conf"
      }
    }
  }
}
