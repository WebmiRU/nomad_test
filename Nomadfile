job "nginx-static" {
  datacenters = ["dc1"]

  group "web" {
    network {
      mode = "bridge"
      port "http" { to = 80 }
    }

    service {
      name = "nginx-static"
      port = "http"
      provider = "nomad"
      tags = [
        "traefik.enable=true",
        "traefik.http.routers.static.rule=Host(`php.b220.ru`)",
        "traefik.http.routers.static.entrypoints=websecure",
        "traefik.http.routers.static.tls=true",
        "traefik.http.routers.static.tls.certresolver=myresolver"
      ]
    }

    # Качаем артефакт в ОБЩУЮ папку группы (alloc)
    task "php" {
      driver = "docker"
      artifact {
        # Снова добавляем принудительный флаг архива
        source      = "https://s3.ru1.storage.beget.cloud/2d858c4489de-black-willow/code2.zip?archive=zip"
        destination = "alloc/repo"
      }
      config {
        image = "php:8.2-fpm-alpine"
        # Пробрасываем общую папку в контейнер PHP
        volumes = [
          "alloc/repo:/var/www/html"
        ]
      }
    }

    task "server" {
      driver = "docker"
      config {
        image = "nginx:alpine"
        volumes = [
          "local/nginx.conf:/etc/nginx/conf.d/default.conf",
          # Пробрасываем ТУ ЖЕ общую папку в контейнер Nginx
          "alloc/repo:/var/www/html"
        ]
      }
      template {
        data = <<EOH
server {
    listen 80;
    root /var/www/html;
    index index.php index.html;

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ \.php$ {
        fastcgi_pass 127.0.0.1:9000;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
    }
}
EOH
        destination = "local/nginx.conf"
      }
    }
  }
}
