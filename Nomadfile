job "php-app" {
  datacenters = ["dc1"]

  group "web" {

    network {
      mode = "bridge"
      port "http" { to = 80 }
      port "fpm"  { to = 9000 }
    }

    service {
      name = "php-app"
      port = "http"
      provider = "nomad"

      tags = [
        "traefik.enable=true",
        "traefik.http.routers.phpapp.rule=Host(`php.b220.ru`)",
        "traefik.http.routers.phpapp.entrypoints=websecure",
        "traefik.http.routers.phpapp.tls=true",
        "traefik.http.routers.phpapp.tls.certresolver=myresolver"
      ]
    }

    # 🐘 PHP (распаковка здесь)
    task "php" {
      driver = "docker"

      artifact {
        source      = "https://s3.ru1.storage.beget.cloud/2d858c4489de-black-willow/code2.zip"
        destination = "local/repo"
        options {
          archive = true
        }
      }

      config {
        image = "php:8.2-fpm-alpine"
        ports = ["fpm"]

        volumes = [
          "local/repo:/var/www/html"
        ]
      }
    }

    # 🌐 NGINX (и здесь тоже, чтобы исключить проблемы шаринга)
    task "nginx" {
      driver = "docker"

      artifact {
        source      = "https://s3.ru1.storage.beget.cloud/2d858c4489de-black-willow/code2.zip"
        destination = "local/repo"
        options {
          archive = true
        }
      }

      config {
        image = "nginx:alpine"
        ports = ["http"]

        volumes = [
          "local/repo:/var/www/html",
          "local/nginx.conf:/etc/nginx/conf.d/default.conf"
        ]
      }

      template {
        destination = "local/nginx.conf"
        data = <<EOF
server {
    listen 80;

    root /var/www/html;
    index index.php index.html;

    location / {
        try_files \$uri \$uri/ /index.php?\$query_string;
    }

    location ~ \\.php$ {
        fastcgi_pass 127.0.0.1:${NOMAD_PORT_fpm};
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME /var/www/html\$fastcgi_script_name;
    }
}
EOF
      }
    }
  }
}